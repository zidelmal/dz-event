// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider        = "prisma-client-js"
  previewFeatures = []
  generatorMode   = "library"
  binaryTargets   = ["native"]
  engineType      = "binary"
  transpile       = "cjs"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// MODELS_START


// >>> event.prisma
model Event {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  type        String?
  startDate   DateTime
  endDate     DateTime
  price       Float?
  posterUrl   String?

  venueId     Int
  wilayaId    Int
  eventTypeId Int

  venue     Venue     @relation(fields: [venueId], references: [id], onDelete: Cascade)
  wilaya    Wilaya    @relation(fields: [wilayaId], references: [id], onDelete: Cascade)
  eventType EventType @relation(fields: [eventTypeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EventType {
  id     Int     @id @default(autoincrement())
  name   String  @unique
  events Event[]
}


// >>> venue.prisma
model Venue {
  id          Int     @id @default(autoincrement())
  name        String
  description String?
  capacity    Int?
  address     String
  phone       String?
  email       String?
  latitude    Float?
  longitude   Float?
  imageUrl    String?

  wilayaId    Int
  venueTypeId Int

  venueType VenueType @relation(fields: [venueTypeId], references: [id])
  wilaya    Wilaya    @relation(fields: [wilayaId], references: [id], onDelete: Cascade)
  events    Event[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VenueType {
  id     Int     @id @default(autoincrement())
  name   String  @unique
  venues Venue[]
}


// >>> wilaya.prisma
model Wilaya {
  id        Int     @id @default(autoincrement())
  name      String  @unique
  code      Int  @unique
  venues    Venue[]
  events    Event[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}