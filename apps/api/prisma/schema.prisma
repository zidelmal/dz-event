// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider        = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
  binaryTargets   = ["native"]
  transpile       = "cjs"
}

datasource db {
  provider = "postgresql"
}

// MODELS_START


// >>> establishment.prisma
model Establishment {
  id          Int     @id @default(autoincrement())
  name        String
  description String?
  capacity    Int?
  address     String
  phone       String?
  email       String?
  latitude    Float?
  longitude   Float?
  imageUrl    String?

  wilayaId    Int
  establishmentTypeId Int

  establishmentType EstablishmentType @relation(fields: [establishmentTypeId], references: [id])
  wilaya    Wilaya    @relation(fields: [wilayaId], references: [id], onDelete: Cascade)
  events    Event[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EstablishmentType {
  id     Int     @id @default(autoincrement())
  name   String  @unique
  establishments Establishment[]
}


// >>> event.prisma
model Event {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  type        String?
  startDate   DateTime
  endDate     DateTime
  price       Float?
  posterUrl   String?

  establishmentId     Int
  wilayaId    Int
  eventTypeId Int

  establishment Establishment @relation(fields: [establishmentId], references: [id], onDelete: Cascade)
  wilaya    Wilaya    @relation(fields: [wilayaId], references: [id], onDelete: Cascade)
  eventType EventType @relation(fields: [eventTypeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EventType {
  id     Int     @id @default(autoincrement())
  name   String  @unique
  events Event[]
}


// >>> wilaya.prisma
model Wilaya {
  id             Int             @id @default(autoincrement())
  name           String          @unique
  code           Int             @unique
  establishments Establishment[]
  events         Event[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}