model Establishment {
  id          Int     @id @default(autoincrement())
  name        String
  description String?
  capacity    Int?
  address     String
  phone       String?
  email       String?
  latitude    Float?
  longitude   Float?
  imageUrl    String?

  wilayaId    Int
  establishmentTypeId Int

  establishmentType EstablishmentType @relation(fields: [establishmentTypeId], references: [id])
  wilaya    Wilaya    @relation(fields: [wilayaId], references: [id], onDelete: Cascade)
  events    Event[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EstablishmentType {
  id     Int     @id @default(autoincrement())
  name   String  @unique
  establishments Establishment[]
}
